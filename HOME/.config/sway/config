# Appearance
include ~/.config/sway/modules/looks.conf

# Defaults
include ~/.config/sway/modules/defaults.conf

# Input devices
include ~/.config/sway/modules/inputs.conf

# Keybinds (movement, utilities, volume, brightness)
include ~/.config/sway/modules/binds.conf

# Workspaces
include ~/.config/sway/modules/workspaces.conf

# Outputs
include ~/.config/sway/modules/outputs.conf

# Layouts
include ~/.config/sway/modules/layout.conf

# Window rules & exec commands
include ~/.config/sway/modules/rules.conf

# Noctalia
include ~/.config/sway/noctalia

# System includes
include /etc/sway/config.d/*
